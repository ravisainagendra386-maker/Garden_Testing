## Garden Test Suite (example)
## Copy to `.env` and fill values.
##
## Tip: you can boot the dashboard without secrets by keeping
## SKIP_ENV_VALIDATE=true (API calls may fail without GARDEN_API_KEY).

GARDEN_ENV=testnet
PORT=3000

# Set true to start dashboard even without secrets.
SKIP_ENV_VALIDATE=true

# Garden Finance API key (required for API tests / quotes)
GARDEN_API_KEY=your-garden-api-key

# Privy (required for full E2E execution)
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret
PRIVY_EVM_WALLET_ID=your-privy-evm-wallet-id
PRIVY_SOLANA_WALLET_ID=your-privy-solana-wallet-id

# Bitcoin (required for BTC route execution)
BTC_PRIVATE_KEY_WIF=generated-in-step-4
BTC_ADDRESS=generated-in-step-4

# Optional behavior
MANUAL_APPROVE=true
ENABLE_E2E=true

# Optional RPC overrides (defaults are provided for common testnets)
# RPC_ETHEREUM=
# RPC_ARBITRUM=
# RPC_BASE=
# RPC_BNBCHAIN=
# RPC_SOLANA=
# RPC_STARKNET=
# RPC_TRON=

